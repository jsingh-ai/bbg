# BBG OPC Dashboard environment file.
# Copy this file to .env and fill in your real values.

APP_NAME=BBG OPC Dashboard
APP_HOST=0.0.0.0
APP_PORT=8000
ENVIRONMENT=production

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=opc_collector
DB_USER=opc_user
DB_PASSWORD=change_me
DB_POOL_SIZE=8
DB_CONNECT_TIMEOUT=8

# This must match opc_machines.machine_id in MySQL.
DEFAULT_MACHINE_ID=1

# Put your photos in backend/app/static/opc_photos by default.
STATIC_PHOTO_DIR=opc_photos

# Collector reads about once per minute, so dashboard refresh is once per minute.
LIVE_REFRESH_SECONDS=60
DEFAULT_HISTORY_MINUTES=60

# Used only when running the Vite dev frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
